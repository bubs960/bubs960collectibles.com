{
  "expo": {
    "name": "FigurePinner",
    "slug": "figurepinner",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "figurepinner",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bubs960.figurepinner",
      "userInterfaceStyle": "dark"
    },
    "android": {
      "package": "com.bubs960.figurepinner",
      "userInterfaceStyle": "dark",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "figurepinner", "host": "figure" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "FigurePinner",
      "shortName": "FigurePinner",
      "description": "Real eBay sold prices for action figures.",
      "themeColor": "#0a0d1c",
      "backgroundColor": "#0a0d1c",
      "lang": "en",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": ["expo-font"]
  }
}
