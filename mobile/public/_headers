# Cloudflare Pages security headers.
# Applies to ALL paths unless overridden by a more-specific block.
#
# CSP is intentionally permissive on `unsafe-inline` for styles because
# react-native-web injects runtime styles via JS-mounted <style> tags.
# Without `unsafe-inline` on style-src, every Text/View/etc. fails to
# render. `script-src` keeps `unsafe-inline` OFF — our bundles are
# hashed JS, never inline scripts.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://figurepinner-api.bubs960.workers.dev https://figurepinner-api-dev.bubs960.workers.dev https://*.clerk.accounts.dev https://*.clerk.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'wasm-unsafe-eval' https://*.clerk.accounts.dev https://*.clerk.com; frame-src https://*.clerk.accounts.dev https://*.clerk.com; manifest-src 'self'; worker-src 'self'

# Long-cache hashed assets. Expo's metro output puts content-hashed
# filenames under /_expo/ so cache-busting is automatic.
/_expo/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker should never be long-cached or new versions can't
# roll out promptly.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest can be revalidated on a short window — content rarely
# changes but the icon URL might.
/manifest.json
  Cache-Control: public, max-age=3600
