# FigurePinner Mobile — environment variables
#
# Expo reads only variables prefixed with EXPO_PUBLIC_ at build time.
# Copy this file to `.env` for local dev, OR configure the same keys on
# EAS Build profiles (recommended for CI). Never commit `.env`.
#
# Three build profiles are supported out of the box — see eas.json:
#   - production    → v1+v2 binary (LAUNCH POSTURE — 2026-04-26 decision)
#   - preview-v1    → v1 read-only fallback (Apple-rejection contingency)
#   - preview-v2    → v2 against the dev Worker (Clerk dev keys)

# ── Always read ──────────────────────────────────────────────────────

# Cloudflare Worker base URL.
# Default falls back to the live Worker if unset; override only for
# staging / preview environments that point at a separate Worker.
#
# preview-v2 EAS profile points at the dev worker:
# EXPO_PUBLIC_FIGUREPINNER_API=https://figurepinner-api-dev.bubs960.workers.dev
EXPO_PUBLIC_FIGUREPINNER_API=https://figurepinner-api.bubs960.workers.dev

# eBay Partner Network campaign ID. Default falls back to the live
# Bubs960 EPN campaign (5339147406) if unset.
EXPO_PUBLIC_EBAY_CAMPAIGN_ID=5339147406

# ── v2 feature flags (LAUNCH POSTURE: ON) ────────────────────────────

# Turns on Clerk auth surface, Own/Want pills, vault + wantlist screens,
# and the pull-sync driver. Leave unset (or "false") for the v1
# fallback profile.
EXPO_PUBLIC_V2_COLLECTION_SYNC=true

# Turns on the Alerts screen, price-alert CTA on the figure detail
# screen, and Expo push-token registration. Paired with
# V2_COLLECTION_SYNC=true.
EXPO_PUBLIC_V2_ALERTS=true

# ── Required when V2_COLLECTION_SYNC=true ────────────────────────────

# Clerk publishable key — safe to ship in the client bundle.
#
# Dev instance (confirmed 2026-04-19, Frontend API: fitting-penguin-70.clerk.accounts.dev):
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_Zml0dGluZy1wZW5ndWluLTcwLmNsZXJrLmFjY291bnRzLmRldiQ
#
# Production key (pk_live_*) still owed — swap in when the Clerk prod
# instance is spun up. The launch binary should use pk_live_*; the
# preview-v2 EAS profile keeps pk_test_* against the dev Worker.

# Clerk JWT template name. LEAVE UNSET — per engineer 2026-04-19, the
# default session token (sub, sid, iss, iat, exp) is enough for v1+v2
# auth. The Worker's JWKS middleware verifies those claims directly.
# EXPO_PUBLIC_CLERK_JWT_TEMPLATE=

# Sentry DSN — deferred to post-launch per engineer 2026-04-19.
# Solo-dev at TestFlight scale is covered by server-side console.log
# + Cloudflare Worker tail. Revisit when user count crosses ~50.
# EXPO_PUBLIC_SENTRY_DSN=
